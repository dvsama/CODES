#include <iostream>
using namespace std;

int main()
{
    string name = "ahmed";

    for (int i = 1; i <= 7; i++)
    {
        for (int k = 0; k < name.length(); k++)
        {
            char ch = name[k];

            for (int j = 1; j <= 5; j++)
            {
                if (ch == 'a')
                {
                    if (j == 1 || j == 5 || i == 1 || i == 4)
                        cout << "*";
                    else
                        cout << " ";
                }
                else if (ch == 'h')
                {
                    if (j == 1 || j == 5 || i == 4)
                        cout << "*";
                    else
                        cout << " ";
                }
                else if (ch == 'm')
                {
                    if (j == 1 || j == 5 || (i == j && j <= 3) || (i + j == 6 && j >= 3))
                        cout << "*";
                    else
                        cout << " ";
                }
                else if (ch == 'e')
                {
                    if (j == 1 || i == 1 || i == 4 || i == 7)
                        cout << "*";
                    else
                        cout << " ";
                }
                else if (ch == 'd')
                {
                    if (j == 1 || i == 1 || i == 7 || (j == 5 && i != 1 && i != 7))
                        cout << "*";
                    else
                        cout << " ";
                }
                else
                {
                    cout << " ";
                }
            }

            cout << "  ";
        }

        cout << endl;
    }

    return 0;
}
